<?xml version="1.0" encoding="UTF-8"?>
<actions>
<action>
	<icon>utilities-terminal</icon>
	<name>Open Terminal Here</name>
	<submenu></submenu>
	<unique-id>1784525290644355-1</unique-id>
	<command>kitty --single-instance --directory %f</command>
	<description>Open kitty terminal in this directory</description>
	<range></range>
	<patterns>*</patterns>
	<startup-notify/>
	<directories/>
</action>
<action>
	<icon>edit-copy</icon>
	<name>Copy Full Path</name>
	<submenu></submenu>
	<unique-id>1784525290644355-2</unique-id>
	<command>bash -c 'echo -n %f | wl-copy'</command>
	<description>Copy the full path to clipboard</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
</action>
<action>
	<icon>edit-copy</icon>
	<name>Copy Filename</name>
	<submenu></submenu>
	<unique-id>1784525290644355-3</unique-id>
	<command>bash -c 'echo -n %n | wl-copy'</command>
	<description>Copy the filename to clipboard</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
</action>
</actions>
